# Brain OS Configuration
# Copy to brain-os.env and fill in your values

# ── Telegram (optional) ──────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN="your-bot-token-here"

# Your chat ID (DM the bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID="your-chat-id-here"

# Topic IDs for group threads (optional — only if using supergroup with topics)
# TELEGRAM_TOPIC_TRADING=16
# TELEGRAM_TOPIC_CONTENT=17
# TELEGRAM_TOPIC_GENERAL=18

# ── Discord (optional) ──────────────────────
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# ── Agent Domains ──────────────────────
# Space-separated list of domains for task queues
BRAIN_OS_DOMAINS="trading content infra"

# ── Cron Window (KST) ──────────────────────
# Heavy tasks run only during this window
# CRON_WINDOW_START=20
# CRON_WINDOW_END=8
